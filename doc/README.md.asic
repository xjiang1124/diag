# Fix "source .tclrc.diag" errors
cd $ASIC_SRC/ip/cosim/common/
ln -s $ASIC_LIB_BUNDLE/asic/asic_lib/_sknobs_swig.so .
ln -s $ASIC_LIB_BUNDLE/asic/asic_lib/_cap_csr_py_if.so .
cd $ASIC_SRC/ip/cosim/capri/
ln -s $ASIC_LIB_BUNDLE/asic/asic_lib/_asic_capri.so .
mkdir -p $ASIC_SRC/ip/cosim/diag/
cd $ASIC_SRC/ip/cosim/diag/
ln -s /$ASIC_LIB_BUNDLE/asic/asic_lib/_asic_diag.so .

