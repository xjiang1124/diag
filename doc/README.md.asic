# Start ASIC environment
# pen-hwlab-pc-01
source .tclrc.diag
# diag_open_j2c_if <usb_NO> <slot_no>
# HAPS1
diag_open_j2c_if 1 10
sknobs_load_file ../haps/cfg/haps_default_sknobs.out
capri_setup 0
# comment to reduce output
#plog_add_scope csr 
cap_top_soft_reset 0

cap_top_init_start 0
cap_top_init_done  0
cap_top_load_from_cfg 0

