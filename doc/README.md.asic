Compilation
tcsh

setenv AWS /home/$USER
setenv AWSD /vol/dump/$USER

setenv ASIC_SRC $AWS/workspace/asic
setenv ASIC_GEN $AWSD/workspace/asic
setenv ASIC_COMMON /home/asic
source $ASIC_COMMON/templates/cshrc_include

cd $ASIC_SRC/ip/cosim/tclsh
source ../diag/setup_diag.csh
gen_rtl -n -j32 diag=1 x86=1

cd $ASIC_SRC/ip/cosim/diag
python gen_asic_lib_bundle.py --arch=x86_64

Bundle
# The entire dependency is available @
cd $ASIC_GEN/ip/cosim/diag/
tar zcvf nic.tar.gz nic/

You need to copy over to the target device. 

Run
To run on target device (x86)
export ASIC_LIB_BUNDLE=<SOME_WRITABLE_LOCATION>
export ASIC_SRC=$ASIC_LIB_BUNDLE/nic/asic_src
export ASIC_GEN=$ASIC_SRC

cd $ASIC_LIB_BUNDLE
tar -zxvf nic.tar.gz
cd $ASIC_LIB_BUNDLE/nic/asic_lib
source source_env_path

start tclsh:
------------

cd $ASIC_SRC/ip/cosim/tclsh
$ASIC_LIB_BUNDLE/nic/asic_lib/diag.exe
source .tclrc.diag

