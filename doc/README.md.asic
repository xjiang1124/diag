export ASIC_LIB_BUNDLE=/home/diag/diag/
export ASIC_SRC=$ASIC_LIB_BUNDLE/asic/asic_src
export ASIC_GEN=$ASIC_SRC

cd $ASIC_LIB_BUNDLE
tar -zxvf nic.tar.gz

cd $ASIC_LIB_BUNDLE/asic/asic_lib
source source_env_path

cd $ASIC_SRC/ip/cosim/tclsh
$ASIC_LIB_BUNDLE/nic/asic_lib/diag.exe
source .tclrc.diag

cd /home/diag/diag/asic/asic_src/ip/cosim/tclsh
source .tclrc.diag

